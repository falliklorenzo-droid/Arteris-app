# ════════════════════════════════════════════════════════════════════════════
# PLANTILLA DE SECRETS — ARTERIS
# ════════════════════════════════════════════════════════════════════════════
# Copiá este archivo como "secrets.toml" (sin .example) y completá los valores.
# NUNCA subas secrets.toml al repositorio (ya está en .gitignore).
#
# En Railway NO se usa este archivo: ahí se cargan como variables de entorno
# (ver GUIA_DEPLOY.md). Este archivo sirve solo para correr la app localmente.
# ════════════════════════════════════════════════════════════════════════════

[supabase]
url = "https://TU-PROYECTO.supabase.co"
key = "TU_SUPABASE_KEY"

[resend]
api_key = "TU_RESEND_API_KEY"

[admin]
email = "tu-email-admin@arterismed.com"
password = "ELEGI_UNA_CONTRASEÑA_FUERTE"

[app]
base_url = "https://arterismed.com"
